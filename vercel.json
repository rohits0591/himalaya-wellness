{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/products", "dest": "/public/products.html" },
    { "src": "/cart", "dest": "/public/cart.html" },
    { "src": "/account", "dest": "/public/account.html" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
