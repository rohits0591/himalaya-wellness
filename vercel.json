{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/style.css",
      "dest": "/public/style.css"
    },
    {
      "src": "/app.js",
      "dest": "/public/app.js"
    },
    {
      "src": "/products",
      "dest": "/public/products.html"
    },
    {
      "src": "/cart",
      "dest": "/public/cart.html"
    },
    {
      "src": "/account",
      "dest": "/public/account.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}